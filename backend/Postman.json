{
  "info": {
    "name": "QuickStock API",
    "_postman_id": "quickstock-2026",
    "description": "QuickStock Inventory Management System – CL2005 Spring 2026",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
